<!-- ABOUT -->
<div class="section" id="about">
  <div class="about-grid">
    <div style="position:relative">
      <div class="km-badge"><div class="km-badge-main">KM</div><div class="km-badge-sub">Certified</div></div>
      <div class="about-img-box">
        <svg viewBox="0 0 200 260" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="30" y1="220" x2="170" y2="220" stroke="rgba(232,69,122,0.3)" stroke-width="2"/>
          <line x1="60" y1="220" x2="85" y2="185" stroke="#E8457A" stroke-width="5" stroke-linecap="round"/>
          <line x1="60" y1="220" x2="55" y2="215" stroke="#E8457A" stroke-width="4" stroke-linecap="round"/>
          <path d="M 85 185 Q 100 155 115 160" stroke="#3B82F6" stroke-width="5" stroke-linecap="round" fill="none"/>
          <line x1="115" y1="160" x2="130" y2="115" stroke="#E8457A" stroke-width="5" stroke-linecap="round"/>
          <line x1="115" y1="160" x2="145" y2="140" stroke="#3B82F6" stroke-width="4" stroke-linecap="round"/>
          <circle cx="85" cy="175" r="11" fill="none" stroke="#E8457A" stroke-width="4"/>
