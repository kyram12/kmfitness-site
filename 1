<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KM Fitness Coach | Youth Gymnastics & Private Coaching</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300;1,600&display=swap" rel="stylesheet">
<style>
  :root {
    --pink:        #E8457A;
    --pink-soft:   #F472B6;
    --pink-pale:   #FCE7F3;
    --blue:        #3B82F6;
    --blue-mid:    #60A5FA;
    --blue-light:  #DBEAFE;
    --bg:          #F0F7FF;
    --bg-mid:      #E4EFFC;
    --bg-card:     #FFFFFF;
    --text-dark:   #1E3A5F;
    --text-body:   #3B5A80;
    --text-muted:  #7BA0C4;
    --white:       #FFFFFF;
  }

  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text-dark);
    font-family: 'Montserrat', sans-serif;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 48px;
    background: rgba(240,247,255,0.9);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(59,130,246,0.12);
    box-shadow: 0 2px 20px rgba(59,130,246,0.06);
  }
  .nav-logo { font-weight: 900; font-size: 20px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-dark); }
  .nav-logo span { color: var(--pink); }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a { font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 0.25s; }
  .nav-links a:hover { color: var(--pink); }
  .nav-cta { background: var(--pink) !important; color: var(--white) !important; padding: 10px 24px !important; transition: background 0.25s !important; }
  .nav-cta:hover { background: var(--pink-soft) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 120px 48px 80px; position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 65% 75% at 85% 45%, rgba(232,69,122,0.13) 0%, transparent 60%),
      radial-gradient(ellipse 55% 65% at 15% 75%, rgba(59,130,246,0.15) 0%, transparent 58%),
      radial-gradient(ellipse 40% 50% at 50% 10%, rgba(96,165,250,0.1) 0%, transparent 55%),
      linear-gradient(160deg, #EFF6FF 0%, #DBEAFE 55%, #F5F0FA 100%);
  }
  .hero::after {
    content: ''; position: absolute; top: -100px; right: -100px;
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(244,114,182,0.13) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-bg-text {
    position: absolute; right: -20px; top: 50%; transform: translateY(-50%);
    font-weight: 900; font-size: clamp(200px, 28vw, 380px); line-height: 1;
    color: rgba(59,130,246,0.055); letter-spacing: -10px; pointer-events: none; user-select: none;
  }
  .hero-inner { position: relative; z-index: 2; max-width: 1100px; margin: 0 auto; width: 100%; }

  .hero-pill {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(232,69,122,0.08); border: 1px solid rgba(232,69,122,0.25); border-radius: 100px;
    padding: 8px 20px; font-size: 11px; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--pink); margin-bottom: 28px; animation: fadeUp 0.6s 0.1s both;
  }
  .hero-pill::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: var(--pink); box-shadow: 0 0 8px rgba(232,69,122,0.6); animation: pulse 1.8s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }

  .hero h1 {
    font-weight: 900; font-size: clamp(52px, 7.5vw, 108px); line-height: 0.92;
    letter-spacing: -2px; color: var(--text-dark); margin-bottom: 12px; animation: fadeUp 0.6s 0.25s both;
  }
  .hero h1 .highlight { color: var(--pink); display: block; }
  .hero h1 .sub { font-weight: 300; font-size: 0.55em; letter-spacing: 6px; color: var(--blue); text-transform: uppercase; display: block; margin-top: 12px; }

  .hero-desc {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: clamp(18px, 2vw, 24px); color: var(--text-body);
    max-width: 560px; line-height: 1.65; margin: 28px 0 44px; animation: fadeUp 0.6s 0.4s both;
  }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; animation: fadeUp 0.6s 0.55s both; }

  .btn {
    display: inline-block; text-decoration: none; font-size: 11px; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase; padding: 17px 40px;
    border: none; cursor: pointer; transition: all 0.3s; font-family: 'Montserrat', sans-serif;
  }
  .btn-red { background: var(--pink); color: var(--white); }
  .btn-red:hover { background: var(--pink-soft); transform: translateY(-2px); box-shadow: 0 12px 32px rgba(232,69,122,0.3); }
  .btn-ghost { border: 1.5px solid rgba(59,130,246,0.3); color: var(--blue); background: transparent; }
  .btn-ghost:hover { border-color: var(--pink); color: var(--pink); }

  .hero-stats {
    display: flex; margin-top: 72px;
    border: 1px solid rgba(59,130,246,0.15); border-radius: 6px; overflow: hidden;
    animation: fadeUp 0.6s 0.7s both; max-width: 680px;
    box-shadow: 0 4px 24px rgba(59,130,246,0.08);
  }
  .hero-stat { flex: 1; padding: 24px 28px; border-right: 1px solid rgba(59,130,246,0.12); background: rgba(255,255,255,0.72); }
  .hero-stat:last-child { border-right: none; }
  .hero-stat-num { font-weight: 900; font-size: 36px; color: var(--text-dark); line-height: 1; margin-bottom: 5px; }
  .hero-stat-num span { color: var(--pink); }
  .hero-stat-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); }

  @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

  /* ── TICKER ── */
  .ticker { background: linear-gradient(90deg, var(--pink) 0%, #C2185B 50%, var(--pink) 100%); padding: 14px 0; overflow: hidden; white-space: nowrap; }
  .ticker-track { display: inline-block; animation: ticker 22s linear infinite; font-weight: 700; font-size: 13px; letter-spacing: 4px; text-transform: uppercase; color: rgba(255,255,255,0.92); }
  @keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }
  .ticker-dot { margin: 0 20px; opacity: 0.5; }

  /* ── LAYOUT ── */
  .section { padding: 100px 48px; max-width: 1160px; margin: 0 auto; }
  .section-full { padding: 100px 48px; background: var(--bg-mid); }
  .section-full-inner { max-width: 1160px; margin: 0 auto; }

  .label { font-size: 10px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--pink); margin-bottom: 14px; }

  h2 { font-weight: 900; font-size: clamp(28px, 4vw, 50px); color: var(--text-dark); line-height: 1.05; margin-bottom: 20px; }
  h2 em { color: var(--blue); font-style: normal; }

  /* ── ABOUT ── */
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }

  .about-img-box {
    background: linear-gradient(135deg, var(--blue-light) 0%, var(--pink-pale) 100%);
    border: 1px solid rgba(59,130,246,0.15); aspect-ratio: 4/5;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden; border-radius: 4px;
    box-shadow: 0 20px 60px rgba(59,130,246,0.12);
  }
  .about-img-box svg { width: 60%; position: relative; z-index: 1; }
  .about-accent { position: absolute; bottom: -16px; right: -16px; width: 80px; height: 80px; background: var(--pink); border-radius: 2px; z-index: -1; }
  .km-badge {
    position: absolute; top: -20px; left: -20px; width: 90px; height: 90px;
    background: var(--white); border: 2px solid var(--pink);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    z-index: 2; box-shadow: 0 8px 24px rgba(232,69,122,0.2);
  }
  .km-badge-main { font-weight: 900; font-size: 28px; color: var(--pink); line-height: 1; }
  .km-badge-sub { font-size: 9px; letter-spacing: 2px; color: var(--text-muted); text-transform: uppercase; }

  .about-body { font-size: 15px; line-height: 1.85; color: var(--text-body); margin-bottom: 18px; }

  .check-list { list-style: none; margin: 28px 0 36px; display: flex; flex-direction: column; gap: 12px; }
  .check-list li { display: flex; align-items: center; gap: 14px; font-size: 14px; font-weight: 600; color: var(--text-dark); }
  .check-list li::before {
    content: '✓'; width: 26px; height: 26px; background: rgba(232,69,122,0.08);
    border: 1px solid rgba(232,69,122,0.3); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: var(--pink); flex-shrink: 0; text-align: center; line-height: 26px;
  }

  /* ── SERVICES ── */
  .services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 52px; }

  .service-card {
    background: var(--white); border: 1px solid rgba(59,130,246,0.1); padding: 48px 32px;
    position: relative; overflow: hidden; transition: all 0.3s; border-radius: 6px;
    box-shadow: 0 4px 20px rgba(59,130,246,0.06);
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(59,130,246,0.14); border-color: rgba(59,130,246,0.25); }
  .service-card.featured { background: linear-gradient(135deg, var(--pink) 0%, var(--pink-soft) 100%); border-color: transparent; box-shadow: 0 12px 40px rgba(232,69,122,0.28); }
  .service-card.featured:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(232,69,122,0.38); }
  .service-card.featured .service-title,
  .service-card.featured .service-desc,
  .service-card.featured .service-price { color: var(--white) !important; }
  .service-card.featured .service-icon { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.35); }

  .service-tag { position: absolute; top: 20px; right: 20px; font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; background: rgba(255,255,255,0.25); color: var(--white); padding: 4px 10px; border-radius: 100px; }
  .service-icon { width: 54px; height: 54px; background: rgba(59,130,246,0.07); border: 1px solid rgba(59,130,246,0.18); display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 28px; border-radius: 4px; }
  .service-title { font-weight: 800; font-size: 20px; color: var(--text-dark); margin-bottom: 14px; }
  .service-desc { font-size: 14px; line-height: 1.78; color: var(--text-body); }
  .service-price { margin-top: 28px; font-weight: 900; font-size: 28px; color: var(--blue); letter-spacing: -1px; }

  /* ── AGE GROUPS ── */
  .age-header { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; }
  .age-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-top: 52px; }

  .age-card {
    background: var(--white); border: 1px solid rgba(59,130,246,0.1); padding: 36px 24px;
    border-radius: 6px; transition: all 0.3s; cursor: default;
    box-shadow: 0 4px 16px rgba(59,130,246,0.05); position: relative; overflow: hidden;
  }
  .age-card::before {
    content: ''; position: absolute; top:0; left:0; right:0; height:3px;
    background: linear-gradient(90deg, var(--blue), var(--pink));
    transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
  }
  .age-card:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(59,130,246,0.12); border-color: rgba(59,130,246,0.2); }
  .age-card:hover::before { transform: scaleX(1); }

  .age-emoji { font-size: 38px; margin-bottom: 16px; display: block; }
  .age-name { font-weight: 800; font-size: 18px; color: var(--text-dark); margin-bottom: 4px; }
  .age-range { font-size: 11px; font-weight: 700; letter-spacing: 2px; color: var(--pink); text-transform: uppercase; margin-bottom: 14px; }
  .age-desc { font-size: 13px; line-height: 1.7; color: var(--text-body); }

  /* ── FOCUS ── */
  .focus-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; margin-top: 52px; }
  .focus-item {
    background: var(--white); border: 1px solid rgba(59,130,246,0.1); padding: 44px 40px;
    display: flex; gap: 24px; align-items: flex-start; border-radius: 6px; transition: all 0.3s;
    box-shadow: 0 4px 16px rgba(59,130,246,0.05);
  }
  .focus-item:hover { border-color: rgba(232,69,122,0.22); box-shadow: 0 12px 32px rgba(232,69,122,0.08); }
  .focus-num {
    font-weight: 900; font-size: 52px; line-height: 1; flex-shrink: 0; margin-top: -8px; letter-spacing: -2px;
    background: linear-gradient(135deg, var(--blue-mid), var(--pink-soft));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .focus-title { font-weight: 800; font-size: 18px; color: var(--text-dark); margin-bottom: 10px; }
  .focus-desc { font-size: 14px; line-height: 1.75; color: var(--text-body); }

  /* ── TESTIMONIALS ── */
  .testimonial-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 52px; }
  .t-card {
    background: var(--white); border: 1px solid rgba(59,130,246,0.1); padding: 36px 30px;
    border-radius: 6px; transition: all 0.3s; box-shadow: 0 4px 16px rgba(59,130,246,0.05);
  }
  .t-card:hover { border-color: rgba(232,69,122,0.2); box-shadow: 0 12px 32px rgba(232,69,122,0.08); }
  .t-stars { color: var(--pink); font-size: 15px; letter-spacing: 2px; margin-bottom: 18px; }
  .t-text { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; line-height: 1.75; color: var(--text-body); margin-bottom: 24px; }
  .t-name { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); }
  .t-role { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  /* ── CONTACT ── */
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .contact-tagline { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 20px; color: var(--text-body); line-height: 1.6; margin-bottom: 40px; }
  .c-item { display: flex; gap: 16px; align-items: center; margin-bottom: 24px; }
  .c-icon { width: 46px; height: 46px; flex-shrink: 0; background: rgba(59,130,246,0.07); border: 1px solid rgba(59,130,246,0.16); display: flex; align-items: center; justify-content: center; font-size: 18px; border-radius: 4px; }
  .c-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--pink); margin-bottom: 3px; }
  .c-val { font-size: 15px; font-weight: 500; color: var(--text-dark); }

  .form { display: flex; flex-direction: column; gap: 14px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  input, select, textarea {
    width: 100%; font-family: 'Montserrat', sans-serif; background: var(--white);
    border: 1px solid rgba(59,130,246,0.15); color: var(--text-dark); font-size: 13px;
    padding: 14px 18px; outline: none; transition: border-color 0.25s; appearance: none; border-radius: 4px;
  }
  input::placeholder, textarea::placeholder { color: var(--text-muted); }
  input:focus, select:focus, textarea:focus { border-color: var(--pink); box-shadow: 0 0 0 3px rgba(232,69,122,0.08); }
  textarea { resize: vertical; min-height: 110px; }
  select option { background: var(--white); color: var(--text-dark); }

  /* ── FOOTER ── */
  footer { background: var(--text-dark); padding: 52px 48px; }
  .footer-inner { max-width: 1160px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px; }
  .f-logo { font-weight: 900; font-size: 22px; letter-spacing: 3px; text-transform: uppercase; color: var(--white); }
  .f-logo span { color: var(--pink); }
  .f-links { display: flex; gap: 28px; flex-wrap: wrap; }
  .f-links a { font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.25s; }
  .f-links a:hover { color: var(--pink-soft); }
  .f-copy { font-size: 11px; color: rgba(255,255,255,0.22); }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    nav { padding: 18px 24px; }
    .nav-links { display: none; }
    .hero, .section { padding-left: 24px; padding-right: 24px; }
    .section-full { padding-left: 24px; padding-right: 24px; }
    .hero-bg-text { display: none; }
    .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 48px; }
    .services-grid, .testimonial-grid, .focus-grid { grid-template-columns: 1fr; }
    .age-grid { grid-template-columns: 1fr 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .hero-stats { flex-direction: column; max-width: 100%; }
    .hero-stat { border-right: none; border-bottom: 1px solid rgba(59,130,246,0.12); }
    .hero-stat:last-child { border-bottom: none; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">KM<span>.</span>Fitness</div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Programs</a></li>
    <li><a href="#ages">Ages</a></li>
    <li><a href="#contact" class="nav-cta">Book Now</a></li>
